{
  "cli": {
    "version": ">= 3.13.3"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://opalengke.com/api",
        "EXPO_PUBLIC_IMAGE_URL": "https://opalengke.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://opalengke.com/api",
        "EXPO_PUBLIC_IMAGE_URL": "https://opalengke.com"
      }
    },
    "production-apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://opalengke.com/api",
        "EXPO_PUBLIC_IMAGE_URL": "https://opalengke.com"
      }
    },
    "production-aab": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://opalengke.com/api",
        "EXPO_PUBLIC_IMAGE_URL": "https://opalengke.com"
      }
    },
    "production": {
      "android": {
        "gradleCommand": ":app:bundleRelease :app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://opalengke.com/api",
        "EXPO_PUBLIC_IMAGE_URL": "https://opalengke.com"
      }
    }
  }
}
