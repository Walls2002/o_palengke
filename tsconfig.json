{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "module": "ESNext",  
    "target": "ESNext",
    "moduleResolution": "Node",  
    "allowImportingTsExtensions": true,
    "strict": true,
    "allowSyntheticDefaultImports": true, 
    "esModuleInterop": true,  
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
